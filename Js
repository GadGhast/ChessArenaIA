// =========================
// ACTUALIZAR RECURSOS
// =========================
async function updateResources(){

  console.log("Actualizando recursos...",new Date());

  // PIB unidades
  const pibPeon = (await db.collection("pib").doc("peon").get()).data();
  const pibAlfil = (await db.collection("pib").doc("alfil").get()).data();
  const pibCaballo = (await db.collection("pib").doc("caballo").get()).data();
  const pibTorre = (await db.collection("pib").doc("torre").get()).data();
  const pibReina = (await db.collection("pib").doc("reina").get()).data();

  const countriesSnapshot = await db.collection("countries").get();

  for(const countryDoc of countriesSnapshot.docs){

    const countryId = countryDoc.id;

    const pibDoc = await db.collection("pib").doc(countryId).get();
    const countryPIB = pibDoc.exists ? pibDoc.data() : {food:0,wood:0,metal:0};

    const citiesSnapshot = await db.collection("countries")
      .doc(countryId)
      .collection("cities")
      .get();

    let totalResources = {food:0,wood:0,metal:0};
    let totalUnits = {peon:0,alfil:0,caballo:0,torre:0,reina:0};

    const citiesData=[];

    for(const cityDoc of citiesSnapshot.docs){

      const city = cityDoc.data();
      const cityName = city.name || cityDoc.id;

      const peon = city.peon || 0;
      const alfil = city.alfil || 0;
      const caballo = city.caballo || 0;
      const torre = city.torre || 0;
      const reina = city.reina || 0;

      const consumoFood =
      (peon * pibPeon.food +
       alfil * pibAlfil.food +
       caballo * pibCaballo.food +
       torre * pibTorre.food +
       reina * pibReina.food) / 168;

      const consumoWood =
      (peon * pibPeon.wood +
       alfil * pibAlfil.wood +
       caballo * pibCaballo.wood +
       torre * pibTorre.wood +
       reina * pibReina.wood) / 168;

      const consumoMetal =
      (peon * pibPeon.metal +
       alfil * pibAlfil.metal +
       caballo * pibCaballo.metal +
       torre * pibTorre.metal +
       reina * pibReina.metal) / 168;

      // valor neto incluyendo alianzas
      const food = round3(
        (city.food || 0) +
        (countryPIB.food * (city.pct_food || 0) / 100) -
        consumoFood +
        (city.ali_food || 0)
      );

      const wood = round3(
        (city.wood || 0) +
        (countryPIB.wood * (city.pct_wood || 0) / 100) -
        consumoWood +
        (city.ali_wood || 0)
      );

      const metal = round3(
        (city.metal || 0) +
        (countryPIB.metal * (city.pct_metal || 0) / 100) -
        consumoMetal +
        (city.ali_metal || 0)
      );

      await cityDoc.ref.update({food,wood,metal});

      totalResources.food += food;
      totalResources.wood += wood;
      totalResources.metal += metal;

      totalUnits.peon += peon;
      totalUnits.alfil += alfil;
      totalUnits.caballo += caballo;
      totalUnits.torre += torre;
      totalUnits.reina += reina;

      citiesData.push({
        name: cityName,
        food, wood, metal,
        peon, alfil, caballo, torre, reina,
        ali_food: city.ali_food || 0,
        ali_wood: city.ali_wood || 0,
        ali_metal: city.ali_metal || 0
      });
    }

    await db.collection("countries").doc(countryId).update({
      food: round3(totalResources.food),
      wood: round3(totalResources.wood),
      metal: round3(totalResources.metal),
      peon: totalUnits.peon,
      alfil: totalUnits.alfil,
      caballo: totalUnits.caballo,
      torre: totalUnits.torre,
      reina: totalUnits.reina,
      lastUpdate: Date.now()
    });

    const payload = construirEmbed(countryId,citiesData,totalResources,totalUnits);
    const webhook = COUNTRY_WEBHOOKS[countryId];

    if(webhook) await enviarWebhook(webhook,payload);
  }

  lastUpdate = Date.now();
  console.log("Actualización terminada");
}

setInterval(updateResources, UPDATE_INTERVAL);
