  const doc = await db.collection("pib").doc("global").get();
  res.json(doc.exists ? doc.data() : {peon:0,alfil:0,caballo:0,torre:0,reina:0});
});

app.get("/",(req,res)=>{
  res.sendFile(path.join(__dirname,"index.html"));
});

app.listen(PORT,()=>{ console.log("Servidor activo puerto",PORT); });
