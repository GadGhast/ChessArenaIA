async function enviarWebhook(webhookURL,payload){
  try{
    await fetch(webhookURL,{
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body:JSON.stringify(payload)
    });
  }catch(err){
    console.error("Webhook error:",err);
  }
}

